# TP/SL Bot — environment config

# Solana RPC endpoint (required)
RPC_URL=https://api.mainnet-beta.solana.com

# Wallet private key (base58, required)
WALLET_PRIVATE_KEY=your_private_key_here

# Dry run mode — evaluates but doesn't send transactions
# DRY_RUN=true

# Telegram bot token (optional, for notifications and /close command)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Telegram chat ID (optional, your chat ID with the bot)
# TELEGRAM_CHAT_ID=1389206094
